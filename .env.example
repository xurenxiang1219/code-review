# 数据库配置
DB_HOST=10.1.96.2
DB_PORT=3308
DB_NAME=ai_code_review
DB_USER=s-hkdev
DB_PASSWORD=G5kOKGb9Aq91rh39
DB_CONNECTION_LIMIT=10
DB_ACQUIRE_TIMEOUT=60000
DB_TIMEOUT=60000

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Git 仓库配置
GIT_REPOSITORY_URL=https://github.com/your-org/your-repo.git
GIT_ACCESS_TOKEN=your_git_token
GIT_WEBHOOK_SECRET=your_webhook_secret
GIT_TARGET_BRANCH=uat

# AI 模型配置
AI_PROVIDER=openai
AI_MODEL=gpt-4
AI_API_KEY=your_ai_api_key
AI_API_BASE_URL=https://api.openai.com/v1
AI_TEMPERATURE=0.3
AI_MAX_TOKENS=4000

# 轮询扫描配置
POLLING_ENABLED=false
POLLING_INTERVAL=300

# 通知配置
NOTIFICATION_EMAIL_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_email_password
NOTIFICATION_FROM_EMAIL=noreply@example.com

# 应用配置
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
LOG_FILE_ENABLED=false
LOG_FILE_PATH=./logs

# 安全配置
JWT_SECRET=your_jwt_secret_at_least_32_characters_long
JWT_ISSUER=ai-code-review-system
JWT_AUDIENCE=ai-code-review-api

# 速率限制配置
API_RATE_LIMIT=100
API_KEY_RATE_LIMIT=1000
WEBHOOK_RATE_LIMIT=50

# AI API 速率限制配置
AI_RATE_LIMIT_WINDOW=60000
AI_RATE_LIMIT_MAX=100
AI_BURST_LIMIT=20
AI_BURST_WINDOW=10000
AI_PROGRESSIVE_LIMIT=true
AI_PROGRESSIVE_THRESHOLD=80

# Webhook 速率限制配置
WEBHOOK_RATE_LIMIT_WINDOW=60000
WEBHOOK_RATE_LIMIT_MAX=50
WEBHOOK_BURST_LIMIT=10
WEBHOOK_BURST_WINDOW=5000
WEBHOOK_PROGRESSIVE_LIMIT=true
WEBHOOK_PROGRESSIVE_THRESHOLD=70
WEBHOOK_IP_WHITELIST=127.0.0.1,::1

# AI 并发控制配置
AI_MAX_CONCURRENCY=10
AI_ACQUIRE_TIMEOUT=300000
AI_LOCK_EXPIRATION=600000
AI_MAX_QUEUE_SIZE=100

# Webhook 并发控制配置
WEBHOOK_MAX_CONCURRENCY=50
WEBHOOK_ACQUIRE_TIMEOUT=30000
WEBHOOK_LOCK_EXPIRATION=60000
WEBHOOK_MAX_QUEUE_SIZE=200

# AI 背压控制配置
AI_BACKPRESSURE_HIGH_WATER=50
AI_BACKPRESSURE_LOW_WATER=20
AI_BACKPRESSURE_MAX_QUEUE=100
AI_BACKPRESSURE_CHECK_INTERVAL=5000
AI_BACKPRESSURE_RECOVERY_DELAY=10000
AI_BACKPRESSURE_DROP_STRATEGY=oldest

# Webhook 背压控制配置
WEBHOOK_BACKPRESSURE_HIGH_WATER=100
WEBHOOK_BACKPRESSURE_LOW_WATER=50
WEBHOOK_BACKPRESSURE_MAX_QUEUE=200
WEBHOOK_BACKPRESSURE_CHECK_INTERVAL=2000
WEBHOOK_BACKPRESSURE_RECOVERY_DELAY=5000
WEBHOOK_BACKPRESSURE_DROP_STRATEGY=newest

# 监控配置
METRICS_RETENTION_HOURS=24
ALERT_CHECK_INTERVAL=30000
MAX_METRICS_PER_NAME=1000
HEALTH_CHECK_INTERVAL=30000

# 加密配置
ENCRYPTION_KEY=your_master_encryption_key_32_chars_min
DB_ENCRYPTION_KEY=your_database_encryption_key_32_chars
CONFIG_ENCRYPTION_KEY=your_config_encryption_key_32_chars
LOG_ENCRYPTION_KEY=your_log_encryption_key_32_chars

# CORS 配置
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.com

# 审查配置
MAX_CONCURRENT_REVIEWS=10
REVIEW_TIMEOUT_MS=120000
MAX_DIFF_LINES=10000
