# AI 代码审查系统 - Polling Scanner 环境变量配置示例

# ================================
# 基础配置
# ================================

# 运行环境
NODE_ENV=production

# 日志级别 (debug, info, warn, error)
LOG_LEVEL=info

# ================================
# 数据库和缓存配置
# ================================

# MySQL 数据库连接字符串
DATABASE_URL=mysql://username:password@localhost:3306/ai_code_review

# Redis 连接字符串
REDIS_URL=redis://localhost:6379

# ================================
# Git 仓库配置
# ================================

# 方式一：单个仓库配置（简单模式）
# GIT_REPOSITORY=owner/repository
# GIT_TARGET_BRANCH=uat
# GIT_TOKEN=your_git_token_here
# GIT_BASE_URL=https://api.github.com

# 方式二：多仓库配置（推荐）
# 仓库列表，逗号分隔
POLLING_REPOSITORIES=myorg/repo1,myorg/repo2,myorg/repo3

# Git 服务配置
GIT_TOKEN=your_git_token_here
GIT_BASE_URL=https://api.github.com

# ================================
# Polling Scanner 全局配置
# ================================

# 默认分支
POLLING_DEFAULT_BRANCH=uat

# 默认扫描间隔（秒，范围：30-3600）
POLLING_DEFAULT_INTERVAL=300

# 优雅关闭超时时间（毫秒）
POLLING_SHUTDOWN_TIMEOUT=30000

# 健康检查间隔（毫秒）
POLLING_HEALTH_CHECK_INTERVAL=60000

# 启用指标记录
POLLING_ENABLE_METRICS=true

# 最大并发扫描器数量
POLLING_MAX_CONCURRENT=10

# ================================
# 仓库特定配置
# ================================

# 为特定仓库配置不同的参数
# 格式：POLLING_{OWNER}_{REPO}_{PARAMETER}
# 注意：owner/repo 中的特殊字符会被转换为下划线，并转为大写

# 示例：myorg/repo1 的配置
POLLING_MYORG_REPO1_BRANCH=main
POLLING_MYORG_REPO1_INTERVAL=180
POLLING_MYORG_REPO1_ENABLED=true
POLLING_MYORG_REPO1_AUTO_ENQUEUE=true
POLLING_MYORG_REPO1_MAX_COMMITS=30

# 示例：myorg/repo2 的配置
POLLING_MYORG_REPO2_BRANCH=develop
POLLING_MYORG_REPO2_INTERVAL=600
POLLING_MYORG_REPO2_ENABLED=true
POLLING_MYORG_REPO2_AUTO_ENQUEUE=true
POLLING_MYORG_REPO2_MAX_COMMITS=50

# 示例：myorg/repo3 的配置（禁用）
POLLING_MYORG_REPO3_ENABLED=false

# ================================
# 监控配置
# ================================

# 监控检查间隔（秒）
POLLING_MONITOR_CHECK_INTERVAL=60

# 最大重启尝试次数
POLLING_MONITOR_MAX_RESTART_ATTEMPTS=5

# 重启窗口期（秒）
POLLING_MONITOR_RESTART_WINDOW=600

# 内存使用阈值（百分比）
POLLING_MONITOR_MEMORY_THRESHOLD=70

# CPU 使用阈值（百分比）
POLLING_MONITOR_CPU_THRESHOLD=80

# 错误日志行数阈值
POLLING_MONITOR_ERROR_LOG_THRESHOLD=20

# ================================
# 告警配置
# ================================

# 告警邮箱
ALERT_EMAIL=admin@example.com

# 告警 Webhook URL（如 Slack、钉钉等）
ALERT_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ================================
# AI 服务配置（用于队列处理）
# ================================

# AI 服务提供商 (openai, anthropic, azure, local)
AI_PROVIDER=openai

# AI API 配置
AI_API_KEY=your_ai_api_key_here
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4
AI_TEMPERATURE=0.3
AI_MAX_TOKENS=4000
AI_TIMEOUT=30000

# ================================
# 队列配置
# ================================

# 队列名称前缀
QUEUE_PREFIX=ai_code_review

# 队列优先级配置
QUEUE_DEFAULT_PRIORITY=0
QUEUE_HIGH_PRIORITY=10

# 任务超时时间（毫秒）
QUEUE_TASK_TIMEOUT=600000

# ================================
# 通知配置
# ================================

# 邮件服务配置
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=your_smtp_password
SMTP_FROM=AI Code Review <noreply@example.com>

# 即时消息配置
IM_WEBHOOK_URL=https://your-im-webhook-url
IM_ENABLED=false

# ================================
# 安全配置
# ================================

# Webhook 签名密钥
WEBHOOK_SECRET=your_webhook_secret_here

# API 访问令牌
API_TOKEN=your_api_token_here

# 加密密钥（用于敏感数据加密）
ENCRYPTION_KEY=your_32_character_encryption_key

# ================================
# 性能配置
# ================================

# Node.js 内存限制
NODE_OPTIONS=--max-old-space-size=2048

# 并发限制
MAX_CONCURRENT_REVIEWS=10
MAX_CONCURRENT_AI_REQUESTS=5

# 缓存配置
CACHE_TTL=3600
CACHE_MAX_SIZE=1000

# ================================
# 开发和调试配置
# ================================

# 启用调试模式
DEBUG=false

# 启用详细日志
VERBOSE_LOGGING=false

# 跳过 AI 审查（仅用于测试）
SKIP_AI_REVIEW=false

# 模拟模式（不实际发布评论）
DRY_RUN=false