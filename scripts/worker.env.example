# AI 代码审查系统 - Worker 环境变量配置示例
# 复制此文件为 worker.env 并根据实际环境修改配置

# ================================
# 基础配置
# ================================

# 运行环境
NODE_ENV=production

# 日志级别 (debug, info, warn, error)
LOG_LEVEL=info

# ================================
# Worker 配置
# ================================

# 最大并发任务数
WORKER_MAX_CONCURRENCY=10

# 轮询间隔（毫秒）
WORKER_POLL_INTERVAL=1000

# 任务超时时间（毫秒，默认 10 分钟）
WORKER_TASK_TIMEOUT=600000

# 优雅关闭超时时间（毫秒，默认 30 秒）
WORKER_SHUTDOWN_TIMEOUT=30000

# 健康检查间隔（毫秒，默认 30 秒）
WORKER_HEALTH_CHECK_INTERVAL=30000

# 启用指标记录
WORKER_ENABLE_METRICS=true

# ================================
# 数据库配置
# ================================

# MySQL 数据库连接
DATABASE_URL=mysql://username:password@localhost:3306/ai_code_review

# MySQL 连接池配置
DB_CONNECTION_LIMIT=10
DB_ACQUIRE_TIMEOUT=60000
DB_TIMEOUT=60000

# ================================
# Redis 配置
# ================================

# Redis 连接
REDIS_URL=redis://localhost:6379/0

# Redis 连接配置
REDIS_MAX_RETRIES_PER_REQUEST=3
REDIS_RETRY_DELAY_ON_FAILURE=100
REDIS_CONNECT_TIMEOUT=10000

# ================================
# AI 服务配置
# ================================

# AI 服务提供商 (openai, anthropic, azure, local)
AI_PROVIDER=openai

# AI 模型名称
AI_MODEL=gpt-4

# AI API 密钥
AI_API_KEY=your_ai_api_key_here

# AI API 基础 URL（可选，用于自定义端点）
AI_BASE_URL=

# AI API 超时时间（毫秒）
AI_API_TIMEOUT=60000

# AI 模型参数
AI_TEMPERATURE=0.3
AI_MAX_TOKENS=4000

# ================================
# Git 服务配置
# ================================

# Git 服务提供商 (github, gitlab, gitea)
GIT_PROVIDER=github

# Git API 访问令牌
GIT_TOKEN=your_git_token_here

# Git API 基础 URL
GIT_BASE_URL=https://api.github.com

# Git API 超时时间（毫秒）
GIT_API_TIMEOUT=30000

# Git API 重试次数
GIT_API_RETRY_ATTEMPTS=3

# ================================
# 通知配置
# ================================

# 邮件通知
EMAIL_NOTIFICATION_ENABLED=true
EMAIL_RECIPIENTS=admin@example.com,team@example.com

# SMTP 配置
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=your_smtp_password

# 即时消息通知（Slack、钉钉等）
IM_NOTIFICATION_ENABLED=false
IM_WEBHOOK_URL=

# ================================
# 监控配置
# ================================

# 监控检查间隔（秒）
MONITOR_CHECK_INTERVAL=30

# 最大重启尝试次数
MONITOR_MAX_RESTART_ATTEMPTS=5

# 重启窗口期（秒）
MONITOR_RESTART_WINDOW=300

# 内存使用阈值（百分比）
MONITOR_MEMORY_THRESHOLD=80

# CPU 使用阈值（百分比）
MONITOR_CPU_THRESHOLD=90

# 错误日志行数阈值
MONITOR_ERROR_LOG_THRESHOLD=50

# 告警邮箱
ALERT_EMAIL=alert@example.com

# 告警 Webhook URL
ALERT_WEBHOOK=

# ================================
# 安全配置
# ================================

# Webhook 签名密钥
WEBHOOK_SECRET=your_webhook_secret_here

# API 访问令牌
API_ACCESS_TOKEN=your_api_token_here

# 加密密钥（用于敏感数据加密）
ENCRYPTION_KEY=your_32_character_encryption_key

# ================================
# 性能配置
# ================================

# 队列清理间隔（秒）
QUEUE_CLEANUP_INTERVAL=3600

# 日志清理保留天数
LOG_RETENTION_DAYS=7

# 审查记录保留天数
REVIEW_RETENTION_DAYS=90

# 最大差异行数（超过此数量将分批处理）
MAX_DIFF_LINES=10000

# 代码上下文行数
CODE_CONTEXT_LINES=5

# ================================
# 开发配置（仅开发环境）
# ================================

# 开发模式下的额外配置
# DEV_MOCK_AI_RESPONSES=false
# DEV_MOCK_GIT_API=false
# DEV_SKIP_WEBHOOK_VERIFICATION=false